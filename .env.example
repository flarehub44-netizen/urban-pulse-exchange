# --- Required (local dev + CI build) ---
# Browser bundle (Vite inlines these at build time)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# SSR / Cloudflare Worker (same values as above; never commit real keys)
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# --- Required for Worker cron, webhooks, football sync (server only) ---
SUPABASE_SERVICE_ROLE_KEY=
SYNCPAY_API_URL=https://api.syncpay.com.br/v1
SYNCPAY_API_KEY=
SYNCPAY_WEBHOOK_SECRET=
# Webhook URL (registrar no painel SyncPay): https://<worker>/api/public/webhooks/syncpay
# Eventos de saque: PAYOUT_COMPLETED, PAYOUT_FAILED

# --- Optional ---
# API_FOOTBALL_KEY=
# CRON_SECRET=              # Legacy Bearer for /api/public/cron/* (prefer CRON_HMAC_SECRET)
# CRON_HMAC_SECRET=         # HMAC for cron routes (football-sync, fraud-cluster-sweep, …)
# VELOCITY_HMAC_SECRET=     # Hash IP/device in BFF velocity checks (min 16 chars)
# SYNCPAY_WEBHOOK_URL=      # e.g. https://viax.life/api/public/webhooks/syncpay
# PUBLIC_DOMAIN=            # e.g. viax.life — CORS on snapshot/hls proxies
# DATABASE_URL=             # CI: SQL acceptance tests
# SENTRY_DSN=
# PLAYWRIGHT_BASE_URL=
# PLAYWRIGHT_TEST_EMAIL=      # E2E: login para testes de /wallet, /positions e funil de depósito
# PLAYWRIGHT_TEST_PASSWORD=
# VITE_PIX_PAYMENTS_ENABLED=true   # false desativa copy/banner Pix no client
# VITE_PARTNER_PAYOUTS_ENABLED=true   # false = saques creator simulados (padrão)
