# --- Required (local dev + CI build) ---
# Browser bundle (Vite inlines these at build time)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# SSR / Cloudflare Worker (same values as above; never commit real keys)
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# --- Required for Worker cron, webhooks, football sync (server only) ---
SUPABASE_SERVICE_ROLE_KEY=
SYNCPAY_API_URL=https://api.syncpay.com.br/v1
SYNCPAY_API_KEY=
SYNCPAY_WEBHOOK_SECRET=

# --- Optional ---
# API_FOOTBALL_KEY=
# CRON_SECRET=              # Bearer for manual /api/cron/* calls
# DATABASE_URL=             # CI: SQL acceptance tests
# SENTRY_DSN=
# PLAYWRIGHT_BASE_URL=
# PLAYWRIGHT_TEST_EMAIL=      # E2E: login para testes de /wallet, /positions e funil de depósito
# PLAYWRIGHT_TEST_PASSWORD=
# VITE_PIX_PAYMENTS_ENABLED=true   # false desativa copy/banner Pix no client
# VITE_PARTNER_PAYOUTS_ENABLED=true   # false = saques creator simulados (padrão)
